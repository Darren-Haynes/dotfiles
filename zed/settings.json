// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "active_pane_modifiers": {
    "border_size": 0.0
  },
  "centered_layout": {
    "right_padding": 0.0,
    "left_padding": 0.0
  },
  "ui_font_weight": 400.0,
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "tree_view": true,
    "dock": "left",
  },
  /* Duplicated key auto-commented: "agent": {
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-5",
      "enable_thinking": true,
      "effort": "high"
    },
    "enabled": true,
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  }, */
  "agent_buffer_font_size": 14.0,
  "ui_font_family": "Galvji",
  "agent_ui_font_size": 14.0,
  "buffer_line_height": "standard",
  "vim_mode": true,
  "relative_line_numbers": "enabled",
  "terminal": {
    "shell": {
      "program": "zsh",
    },
    "font_weight": 395.0,
    "toolbar": {
      "breadcrumbs": false,
    },
    "font_family": "SpaceMono Nerd Font Propo",
    "font_size": 15.0,
  },
  "base_keymap": "VSCode",
  "status_bar": {
    "experimental.show": false,
  },
  "tab_bar": {
    "show": false,
  },
  "sticky_scroll": {
    "enabled": false,
  },
  "minimap": {
    "show": "never",
  },
  "title_bar": {
    "show_onboarding_banner": false,
    "show_project_items": false,
    "show_branch_name": false,
    "show_user_menu": false,
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "scrollbar": {
    "axes": {
      "vertical": false,
    },
  },
  "buffer_font_fallbacks": ["Menlo", "Monaco", "Courier New", "monospace"],
  "buffer_font_family": "Symbols Nerd Font Mono",
  "linked_edits": true,
  "icon_theme": "Zed (Default)",
  "ui_font_size": 15.0,
  "buffer_font_size": 16.0,
  "theme": {
    "mode": "dark",
    "light": "Gruvbox Light Soft",
    "dark": "One Dark",
  },
  "which_key": { "enabled": true },
  "project_panel": {
    "dock": "left",
    "hide_root": true,
    "auto_fold_dirs": false,
    "sticky_scroll": false,
    "default_width": 400,
    "scrollbar": {
      "show": "never",
    },
    "indent_guides": {
      "show": "never",
    },
  },
  "outline_panel": {
    "dock": "left",
    "default_width": 400,
  },
  "gutter": {
    "min_line_number_digits": 0,
    "folds": false,
  },
  // Syntax highlighting for alias files
  "file_types": {
    "Shell Script": ["alias", "aliases"],
  },
    "language_models": {
      "ollama": {
        "api_url": "http://localhost:11434",
        "auto_discover": true
      }
    },
    "agent": {
      "sidebar_side": "right",
      "dock": "right",
      "default_model": {
        "provider": "ollama",
        "model": "qwen2.5-coder:7b"
      }
    },
    "edit_predictions": {
      "provider": "ollama",
      "ollama": {
        "model": "qwen2.5-coder:14b",
        "prompt_format": "infer"
      }
    }
}
