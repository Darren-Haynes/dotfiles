# LISTING
alias l='ls -lA'
alias lsfonts='ls /usr/share/fonts/'

# lSD
alias ls='lsd'
alias l='ls -l'
alias la='ls -a'
alias lla='ls -la'
alias lt='ls --tree'

# PYTHON
alias idarren="ipython --profile=darren"
alias ptest="pytest -q --cov --cov-report=term-missing"
alias jf="python main.py"

# IMAGES
alias r90="convert -rotate 90 " # then 'from.jpg' to 'to.jpg'
alias r180="convert -rotate 180 " # then 'from.jpg' to 'to.jpg'

# GITHUB / VERSION CONTROL
alias ga='git add --all .'
alias gca='git commit --all'
alias gd='git diff '
alias gc="git commit -m "
alias gst='git status'
alias gg='git log --all --graph'
alias parent="git log --pretty=format:'%D' HEAD^ | grep 'origin/' | head -n1 | sed 's@origin/@@' | sed 's@,.*@@'"

# GITHUB / PUSH
alias pushm='git push origin main'
alias pushmast='git push origin master'
alias pusht='git push origin testing'
alias pushf='git push origin front-end'

# GITHUB / PULL
alias pullm='git pull origin main'
alias pullmast='git pull origin master'
alias pullt='git pull origin testing'
alias pullf='git pull origin front-end'

# GITHUB / SWITCH & CHECKOUT
alias gomain='git switch main'
alias gomast='git switch master'
alias got='git switch testing'
alias gof='git switch front-end'

# NODE / NPM / NPX
alias ns='npm run start'
alias play='npx playwright test'

# LINUX SHORTCUTS
alias ag='alias | grep '
alias c='clear'
alias caps='setxkbmap -option caps:escape'
alias fontlist="fc-list : family | sort" # works on linux and macos
alias hg='history | grep '
alias ht='history | tail '
alias now="date '+%R'"

# COPY
alias copy='xsel --clipboard < '

# SOURCING
alias soa='source ~/.aliases'
alias sob='source ~/.bashrc'
alias soz='source ~/.zshrc'

# MACOS
alias icloud="cd ~/Library/Mobile\ Documents/com~apple~CloudDocs/"
alias spanish="cd ~/Library/Mobile\ Documents/com~apple~CloudDocs/Spanish"
alias spanish-study="nvim ~/Library/Mobile\ Documents/com\~apple\~CloudDocs/Spanish/AI-Book/Spanish-Book-AI*"


# NETWORKING
alias myip='curl ifconfig.me'
